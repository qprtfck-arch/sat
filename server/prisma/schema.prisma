generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     String @default("student") // student | teacher | admin

  // onboarding profile
  grade     Int?
  interests String  @default("") // CSV of direction tags
  subjects  String  @default("") // CSV of subjects
  goals     String  @default("") // CSV of goals
  language  String  @default("ru")
  onboarded Boolean @default(false)

  // gamification
  coins          Int       @default(50)
  streak         Int       @default(0)
  lastStreakDate DateTime?
  pairedWithId   String? // partner for Social-to-Learn paired streak

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saved            SavedOpportunity[]
  enrollments      Enrollment[]
  progress         LessonProgress[]
  authoredCourses  Course[]           @relation("CourseAuthor")
  coinTransactions CoinTransaction[]
  inventory        InventoryItem[]
}

model Opportunity {
  id           String    @id @default(uuid())
  title        String
  category     String
  direction    String
  format       String
  deadline     DateTime?
  description  String
  requirements String    @default("")
  applyUrl     String    @default("")
  gradeMin     Int       @default(8)
  gradeMax     Int       @default(12)
  tags         String    @default("")
  location     String    @default("Online")
  organizer    String    @default("Mentoria")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  savedBy SavedOpportunity[]
}

model SavedOpportunity {
  id            String   @id @default(uuid())
  userId        String
  opportunityId String
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  level       String   @default("Beginner")
  subject     String   @default("")
  direction   String   @default("")
  tags        String   @default("")
  emoji       String   @default("📘")
  color       String   @default("#6366f1")
  authorId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User?        @relation("CourseAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  lessons     Lesson[]
  enrollments Enrollment[]
}

model Lesson {
  id          String   @id @default(uuid())
  courseId    String
  order       Int      @default(0)
  title       String
  content     String   @default("")
  videoUrl    String   @default("")
  durationMin Int      @default(10)
  quiz        String   @default("") // JSON string
  createdAt   DateTime @default(now())

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model LessonProgress {
  id          String    @id @default(uuid())
  userId      String
  lessonId    String
  completed   Boolean   @default(false)
  quizScore   Int?
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

// ---- gamification ----

model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String
  amount    Int // positive = earned, negative = spent
  type      String // signup, streak, lesson, trivia, case, gift_in, gift_out, promo
  meta      String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InventoryItem {
  id         String   @id @default(uuid())
  userId     String
  itemType   String // emoji/skin/badge identifier
  name       String
  rarity     String // Common | Rare | Epic | Legendary
  isEquipped Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
