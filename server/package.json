{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon --watch src --ext js src/index.js",
    "start": "node src/index.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "db:setup": "prisma generate && prisma db push --accept-data-loss && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.9.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
